      <aliases enabled='yes' />
      <column caption='Cltv' datatype='integer' name='[CLTV]' role='measure' type='quantitative' />
      <column caption='Churned_lifecycle' datatype='real' name='[Calculation_0340436388274179]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Churn] = &apos;Yes&apos; THEN [tenure] END)' />
      </column>
      <column caption='Retained_Lifecycle' datatype='real' name='[Calculation_0340436388896772]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG( IF [Churn] = &apos;No&apos; THEN [tenure] END )' />
      </column>
      <column caption='Life Cycle Reduction' datatype='real' default-format='p0.00%' name='[Calculation_0340436392992774]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#10;  AVG(IF [Churn] = &quot;No&quot; THEN [tenure] END)&#10;  -&#10;  AVG(IF [Churn] = &quot;Yes&quot; THEN [tenure] END)&#10;)&#10;/&#10;AVG(IF [Churn] = &quot;No&quot; THEN [tenure] END)' />
      </column>
      <column caption='Sticky Score' datatype='integer' name='[Calculation_0340436417728520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(IF [StreamingTV] = &quot;Yes&quot; THEN 1 ELSE 0 END) +&#10;(IF [StreamingMovies] = &quot;Yes&quot; THEN 1 ELSE 0 END) +&#10;(IF [DeviceProtection] = &quot;Yes&quot; THEN 1 ELSE 0 END) +&#10;(IF [OnlineSecurity] = &quot;Yes&quot; THEN 1 ELSE 0 END) +&#10;(IF [MultipleLines] = &quot;Yes&quot; THEN 1 ELSE 0 END) +&#10;(IF [OnlineBackup] = &quot;Yes&quot; THEN 1 ELSE 0 END) +&#10;(IF [TechSupport] = &quot;Yes&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Rev_lost' datatype='real' name='[Calculation_0340504896724992]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN [TotalCharges] ELSE 0 END' />
      </column>
      <column caption='Churn_Rate' datatype='real' name='[Calculation_0340504900370433]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNT(IF [Churn] = &apos;Yes&apos; THEN [customerID] END) / COUNT([customerID])) * 100' />
      </column>
      <column datatype='string' name='[Churn Label]' role='dimension' type='nominal' />
