    <worksheet name='LifeCycle'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Life Cycle Reduction of</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='WA_Fn-UseC_-Telco-Customer-Churn' name='federated.0hckzyp1364xdk1evifxo0ey67cw' />
          </datasources>
          <datasource-dependencies datasource='federated.0hckzyp1364xdk1evifxo0ey67cw'>
            <column caption='Life Cycle Reduction' datatype='real' default-format='p0.00%' name='[Calculation_0340436392992774]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#10;  AVG(IF [Churn] = &quot;No&quot; THEN [tenure] END)&#10;  -&#10;  AVG(IF [Churn] = &quot;Yes&quot; THEN [tenure] END)&#10;)&#10;/&#10;AVG(IF [Churn] = &quot;No&quot; THEN [tenure] END)' />
            </column>
            <column datatype='string' name='[Churn]' role='dimension' type='nominal' />
            <column caption='Life Cycle Revenue Loss' datatype='real' default-format='C4105%' name='[Life Cycle Reduction (copy)_0340436397768711]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(AVG(IF [Churn] = &quot;No&quot; THEN [tenure] END) - AVG(IF [Churn] = &quot;Yes&quot; THEN [tenure] END))&#10;*&#10;AVG(IF [Churn] = &quot;Yes&quot; THEN [MonthlyCharges] END)' />
            </column>
            <column caption='Monthly Charges' datatype='real' name='[MonthlyCharges]' role='measure' type='quantitative' />
            <column caption='Tenure' datatype='integer' name='[tenure]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0340436392992774]' derivation='User' name='[usr:Calculation_0340436392992774:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Life Cycle Reduction (copy)_0340436397768711]' derivation='User' name='[usr:Life Cycle Reduction (copy)_0340436397768711:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
